# Copy to `.env` before running `docker compose up`.
# Anything marked REQUIRED must be set or the stack will refuse to start.

# --- Postgres ---
POSTGRES_USER=rep
POSTGRES_PASSWORD=rep
POSTGRES_DB=rep

# --- Backend ---
APP_ENV=development
DEBUG=false
# REQUIRED: generate with `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-to-a-long-random-string

# JSON array of origins allowed for browser CORS.
# In the default compose setup the SPA is same-origin with the API (both behind nginx),
# so this can usually be left as `[]`. Add http://localhost:5173 when using Vite dev server.
CORS_ORIGINS=["http://localhost","http://localhost:5173"]

# Optional: auto-create an admin user on first boot.
FIRST_ADMIN_EMAIL=
FIRST_ADMIN_PASSWORD=

# --- Redis ---
# Leave empty for local Docker Compose (uses the redis service).
# Set to full URL for managed providers (Upstash, Railway, etc).
# Format: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=
# These are used only when REDIS_URL is empty (local Compose):
# REDIS_HOST=redis
# REDIS_PORT=6379

# --- Stripe (test mode) ---
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from `stripe listen --forward-to ...` for local webhook testing
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=inr

# --- Edge ---
# Host port the public nginx reverse proxy binds to. Change if 80 is taken.
HTTP_PORT=80
