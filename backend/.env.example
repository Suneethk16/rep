# ─── App ─────────────────────────────────────────────────────────────
APP_NAME=rep-ecommerce-api
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Security ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-32-byte-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=rep
POSTGRES_PASSWORD=rep_dev_password
POSTGRES_DB=rep
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Used by SQLAlchemy (async)
DATABASE_URL=postgresql+asyncpg://rep:rep_dev_password@postgres:5432/rep
# Used by Alembic (sync)
DATABASE_URL_SYNC=postgresql+psycopg://rep:rep_dev_password@postgres:5432/rep

# ─── Redis (cache + Celery broker/results) ───────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_BROKER_DB=1
REDIS_RESULT_DB=2
PRODUCT_CACHE_TTL_SECONDS=60

# ─── Celery ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Admin bootstrap (first-run seed) ────────────────────────────────
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme-strong-password
